# Formspree endpoint for the contact form.
# Create a form at https://formspree.io (delivers to the email on the account),
# then copy its endpoint URL here. Also add this var in Vercel project settings.
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/your_form_id

# Google Gemini API key for the Fulcrum AI chat assistant (/api/chat serverless function).
# Get a free key at: https://aistudio.google.com/app/apikey
# Add this to Vercel project settings → Environment Variables (NOT prefixed with VITE_ — server-side only).
GEMINI_API_KEY=AIza...
